# CONFIGURACIÓN DE ACCESO COMERCIAL DE FIREBASE
# Si dejas las variables con los valores por defecto (tu_project_id, etc.),
# la aplicación funcionará de manera automática en MODO SIMULADOR (sin coste y en local).
# Cuando crees tu cuenta real de Firebase, reemplaza estos valores con tus credenciales.

VITE_FIREBASE_API_KEY=tu_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu_auth_domain
VITE_FIREBASE_PROJECT_ID=tu_project_id
VITE_FIREBASE_STORAGE_BUCKET=tu_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=tu_messaging_sender_id
VITE_FIREBASE_APP_ID=tu_app_id
